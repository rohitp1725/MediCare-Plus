# Supabase project settings (Project Settings > API in the Supabase dashboard)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-side only — used by Edge Functions / report generation.
# NEVER expose this in frontend code or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# AI features (chatbot, health summaries, insights)
# Used only from Supabase Edge Functions, never from the browser.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
